# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=False

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is fine for a demo. Switch to postgres://user:pass@host/db for prod.
DATABASE_URL=sqlite:///db.sqlite3

# ── Hosts & trusted origins ───────────────────────────────────────────────────
ALLOWED_HOSTS=54.252.235.169,ec2-54-252-235-169.ap-southeast-2.compute.amazonaws.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://54.252.235.169,http://ec2-54-252-235-169.ap-southeast-2.compute.amazonaws.com
CORS_ALLOWED_ORIGINS=http://54.252.235.169,http://ec2-54-252-235-169.ap-southeast-2.compute.amazonaws.com

# ── Wagtail ───────────────────────────────────────────────────────────────────
WAGTAILADMIN_BASE_URL=http://54.252.235.169

# ── Media (persistent on EC2 — NOT /tmp/) ────────────────────────────────────
# Any images/files uploaded via the Wagtail admin will be stored here.
# Nginx serves this directory at /media/.
MEDIA_URL=/media/
MEDIA_ROOT=/home/ubuntu/rgp-wag/backend/media

# ── Static files ──────────────────────────────────────────────────────────────
# STATIC_ROOT is auto-computed by Django as <backend_dir>/staticfiles.
# It is NOT configurable via env (see base.py). After running collectstatic,
# files land at: /home/ubuntu/rgp-wag/backend/staticfiles/
# Nginx serves that directory at /static/.

# ── Django settings module ────────────────────────────────────────────────────
# Use demo.py for HTTP-only EC2 demo (disables secure-cookie / HSTS flags).
# Switch to config.settings.production when HTTPS/SSL is configured.
DJANGO_SETTINGS_MODULE=config.settings.demo

# ── HTTP demo overrides (read by config/settings/demo.py) ────────────────────
# Set both to True and update CSRF_TRUSTED_ORIGINS/CORS_ALLOWED_ORIGINS to
# https:// URLs once you add SSL certificates.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── Optional email ────────────────────────────────────────────────────────────
# Leave blank to silently skip email sending during the demo.
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@realgoldproperties.com.au
